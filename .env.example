# ================================
# Convex backend URL
# ================================
# Get this from your Convex dashboard after running `npx convex dev`.
# Looks like: https://your-deployment-name.convex.cloud
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ================================
# EmailJS configuration (for booking confirmation emails)
# ================================
# Sign up at https://www.emailjs.com (free 200 emails/month)
# Then create one Email Service (Gmail recommended) and two templates.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_PATIENT_TEMPLATE=template_patient_xxxx
VITE_EMAILJS_CLINIC_TEMPLATE=template_clinic_xxxx
